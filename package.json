{
  "name": "poetry_graph",
  "version": "1.0.0",
  "description": "An instrument for seeing, building, and performing the sound-structure of poems",
  "scripts": {
    "start": "concurrently -n api,web -c yellow,cyan \"node backend/server.js\" \"http-server public -p 3000 -c-1 --silent\"",
    "postinstall": "cd backend && npm install"
  },
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "concurrently": "^9.1.0",
    "http-server": "^14.1.1"
  }
}
